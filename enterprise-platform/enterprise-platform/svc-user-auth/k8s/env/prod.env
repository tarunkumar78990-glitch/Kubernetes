# Environment values for user-auth / prod
# Consumed by scripts/deploy.sh via envsubst. This is our substitute for
# Helm values / Kustomize overlays, per the no-Helm/no-Kustomize constraint.

ENVIRONMENT=prod
NAMESPACE=prod

REPLICAS=2
LOG_LEVEL=info

CPU_REQUEST=100m
MEMORY_REQUEST=192Mi
MEMORY_LIMIT=512Mi

HPA_MIN=2
HPA_MAX=6

PDB_MIN_AVAILABLE=1
