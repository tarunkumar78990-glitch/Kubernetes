{
  "title": "Platform Overview",
  "uid": "platform-overview",
  "tags": [
    "platform",
    "slo"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "custom",
        "query": "dev,staging,prod",
        "current": {
          "text": "dev",
          "value": "dev"
        },
        "options": [
          {
            "text": "dev",
            "value": "dev",
            "selected": true
          },
          {
            "text": "staging",
            "value": "staging",
            "selected": false
          },
          {
            "text": "prod",
            "value": "prod",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error budget remaining (30d)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "slo:frontend:error_budget_remaining",
          "legendFormat": "frontend",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:checkout:error_budget_remaining",
          "legendFormat": "checkout",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:payment:error_budget_remaining",
          "legendFormat": "payment",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:order:error_budget_remaining",
          "legendFormat": "order",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:cart:error_budget_remaining",
          "legendFormat": "cart",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:product_catalog:error_budget_remaining",
          "legendFormat": "product-catalog",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:user_auth:error_budget_remaining",
          "legendFormat": "user-auth",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:shipping:error_budget_remaining",
          "legendFormat": "shipping",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:notification:error_budget_remaining",
          "legendFormat": "notification",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:recommendation:error_budget_remaining",
          "legendFormat": "recommendation",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.25
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
    {
      "id": 2,
      "title": "Request rate by service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Error rate (5xx) by service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (app) (rate(http_requests_total{namespace=\"$namespace\",status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "p99 latency by service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (app, le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "p50 latency by service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (app, le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "{{app}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Dependency call failures",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (app, dependency) (rate(dependency_requests_total{namespace=\"$namespace\",status=\"failure\"}[5m]))",
          "legendFormat": "{{app}} -> {{dependency}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "reqps"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Success ratio vs SLO target",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "slo:frontend:success_ratio5m",
          "legendFormat": "frontend",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:checkout:success_ratio5m",
          "legendFormat": "checkout",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:payment:success_ratio5m",
          "legendFormat": "payment",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:order:success_ratio5m",
          "legendFormat": "order",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:cart:success_ratio5m",
          "legendFormat": "cart",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:product_catalog:success_ratio5m",
          "legendFormat": "product-catalog",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:user_auth:success_ratio5m",
          "legendFormat": "user-auth",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:shipping:success_ratio5m",
          "legendFormat": "shipping",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:notification:success_ratio5m",
          "legendFormat": "notification",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "slo:recommendation:success_ratio5m",
          "legendFormat": "recommendation",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Pod restarts",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[15m]))",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Memory usage vs limit",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\",container!=\"\"}) / sum by (pod) (container_spec_memory_limit_bytes{namespace=\"$namespace\",container!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
          },
          "unit": "percentunit"
        },
        "overrides": []
      }
    }
  ]
}