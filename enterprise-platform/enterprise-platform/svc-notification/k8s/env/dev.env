# Environment values for notification / dev
# Consumed by scripts/deploy.sh via envsubst. This is our substitute for
# Helm values / Kustomize overlays, per the no-Helm/no-Kustomize constraint.

ENVIRONMENT=dev
NAMESPACE=dev

REPLICAS=1
LOG_LEVEL=debug

CPU_REQUEST=50m
MEMORY_REQUEST=96Mi
MEMORY_LIMIT=256Mi

HPA_MIN=1
HPA_MAX=3

PDB_MIN_AVAILABLE=0
