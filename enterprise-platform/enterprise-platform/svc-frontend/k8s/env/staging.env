# Environment values for frontend / staging
# Consumed by scripts/deploy.sh via envsubst. This is our substitute for
# Helm values / Kustomize overlays, per the no-Helm/no-Kustomize constraint.

ENVIRONMENT=staging
NAMESPACE=staging

REPLICAS=2
LOG_LEVEL=info

CPU_REQUEST=75m
MEMORY_REQUEST=128Mi
MEMORY_LIMIT=384Mi

HPA_MIN=2
HPA_MAX=4

PDB_MIN_AVAILABLE=1
